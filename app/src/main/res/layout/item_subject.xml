<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:layout_height="wrap_content">

    <!-- Subject Image -->
    <ImageView
        android:id="@+id/imageViewSubjectImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/app_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Subject Name -->
    <TextView
        android:id="@+id/textViewSubjectName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Subject Name"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/imageViewSubjectImage"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp" />

    <!-- Tutor Experience -->
    <TextView
        android:id="@+id/textViewTutorExperience"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Experience"
        app:layout_constraintTop_toBottomOf="@id/textViewSubjectName"
        app:layout_constraintStart_toStartOf="@id/textViewSubjectName"
        app:layout_constraintEnd_toEndOf="@id/textViewSubjectName"
        android:layout_marginTop="8dp" />

    <!-- Subject Description -->
    <TextView
        android:id="@+id/textViewSubjectDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Subject Description"
        app:layout_constraintTop_toBottomOf="@id/textViewTutorExperience"
        app:layout_constraintStart_toStartOf="@id/textViewSubjectName"
        app:layout_constraintEnd_toEndOf="@id/textViewSubjectName"
        android:layout_marginTop="8dp" />

    <!-- Subject Category -->
    <TextView
        android:id="@+id/textViewSubjectCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Category"
        app:layout_constraintTop_toBottomOf="@id/textViewSubjectDescription"
        app:layout_constraintStart_toStartOf="@id/textViewSubjectName"
        app:layout_constraintEnd_toEndOf="@id/textViewSubjectName"
        android:layout_marginTop="8dp" />

    <!-- Tutor Qualifications -->
    <TextView
        android:id="@+id/textViewTutorQualifications"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Qualifications"
        app:layout_constraintTop_toBottomOf="@id/textViewSubjectCategory"
        app:layout_constraintStart_toStartOf="@id/textViewSubjectName"
        app:layout_constraintEnd_toEndOf="@id/textViewSubjectName"
        android:layout_marginTop="8dp" />

    <!-- Hourly Rate -->
    <TextView
        android:id="@+id/textViewHourlyRate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Hourly Rate"
        app:layout_constraintTop_toBottomOf="@id/textViewTutorQualifications"
        app:layout_constraintStart_toStartOf="@id/textViewSubjectName"
        app:layout_constraintEnd_toEndOf="@id/textViewSubjectName"
        android:layout_marginTop="8dp" />

    <!-- Location -->
    <TextView
        android:id="@+id/textViewLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Location"
        app:layout_constraintTop_toBottomOf="@id/textViewHourlyRate"
        app:layout_constraintStart_toStartOf="@id/textViewSubjectName"
        app:layout_constraintEnd_toEndOf="@id/textViewSubjectName"
        android:layout_marginTop="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
